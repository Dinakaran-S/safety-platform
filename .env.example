# Copy this file to .env and fill in a key for AT LEAST ONE provider below to
# enable real LLM-generated Agent 5 incident narratives + the AI Safety
# Copilot. You can also skip this entirely and set a key from the
# dashboard's "AI Settings" panel instead — no restart needed either way.
#
# If neither is set, SENTINEL runs exactly as before: Agent 5 falls back to
# its deterministic template narrative generator, and the Copilot falls back
# to "unknown command". Nothing else changes.

# ── Anthropic (Claude) ──────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Groq ─────────────────────────────────────────────────────────────────
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# If both are set, Anthropic is used by default — switch providers anytime
# from the AI Settings panel in the dashboard.

# Optional:
# SENTINEL_LLM_MAX_TOKENS=220
